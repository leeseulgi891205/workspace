<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd" id="WebApp_ID" version="4.0">
  <display-name>p0205_03</display-name>
  <!-- Front Controller: handle all *.do requests -->
  <servlet>
    <servlet-name>FController</servlet-name>
    <servlet-class>com.java.www.controller.FController</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>FController</servlet-name>
    <url-pattern>*.do</url-pattern>
  </servlet-mapping>

  <!-- JNDI DataSource reference (Tomcat context provides the actual Resource) -->
  <resource-ref>
    <description>Oracle XE DataSource</description>
    <res-ref-name>jdbc/Oracle21</res-ref-name>
    <res-type>javax.sql.DataSource</res-type>
    <res-auth>Container</res-auth>
  </resource-ref>

  <!-- Start page -->
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>
</web-app>