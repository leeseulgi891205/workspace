<?xml version="1.0" encoding="UTF-8"?>
<Context>
    <!-- Oracle Database Connection Pool -->
    <Resource 
        name="jdbc/Oracle11g" 
        auth="Container"
        type="javax.sql.DataSource"
        driverClassName="oracle.jdbc.OracleDriver"
        url="jdbc:oracle:thin:@localhost:1521:xe"
        username="ora_user"
        password="1111"
        maxTotal="20"
        maxIdle="10"
        maxWaitMillis="-1"/>
</Context>
