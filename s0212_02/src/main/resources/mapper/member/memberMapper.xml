<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.java.dao.memberMapper">
	<select id="selectLogin" parameterType="com.java.dto.MemberDto" resultType="com.java.dto.MemberDto">
		SELECT * FROM (
			SELECT * FROM member
			WHERE id = #{id} AND pw = #{pw}
		) WHERE ROWNUM = 1
	</select>

	<insert id="insertMember" parameterType="com.java.dto.MemberDto">
		insert into member values
		(#{id},#{pw},#{name},#{phone},#{email},#{gender},#{hobby})
	</insert>


</mapper>
